enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
  no_show
}

model TeacherAvailability {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacherId    String    @map("teacher_id") @db.Uuid
  teacher      User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  dayOfWeek    Int       @map("day_of_week") @db.SmallInt
  startTime    String    @map("start_time") @db.VarChar(5)
  endTime      String    @map("end_time") @db.VarChar(5)
  isRecurring  Boolean   @default(true) @map("is_recurring")
  validFrom    DateTime? @map("valid_from") @db.Date
  validUntil   DateTime? @map("valid_until") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("teacher_availability")
}

model IndividualBooking {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId        String        @map("course_id") @db.Uuid
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId       String        @map("student_id") @db.Uuid
  student         User          @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  teacherId       String        @map("teacher_id") @db.Uuid
  teacher         User          @relation("TeacherBookings", fields: [teacherId], references: [id], onDelete: Cascade)
  slotStart       DateTime      @map("slot_start") @db.Timestamptz
  slotEnd         DateTime      @map("slot_end") @db.Timestamptz
  meetLink        String?       @map("meet_link") @db.Text
  calendarEventId String?       @map("calendar_event_id") @db.VarChar(255)
  status          BookingStatus @default(pending)
  orderId         String?       @map("order_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("individual_bookings")
}

enum PaymentGateway {
  razorpay
  stripe
  upi
}

enum PaymentPurpose {
  course_purchase
  teacher_onboarding
  corporate_subscription
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  refunded
}

enum OrderStatus {
  pending
  paid
  failed
  refunded
  cancelled
}

enum RefundStatus {
  requested
  approved
  rejected
  processed
}

model Payment {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String          @map("user_id") @db.Uuid
  user             User            @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  amount           Decimal         @db.Decimal(12, 2)
  currency         String          @default("INR") @db.Char(3)
  gateway          PaymentGateway
  gatewayPaymentId String?         @unique @map("gateway_payment_id") @db.VarChar(255)
  purpose          PaymentPurpose
  status           PaymentStatus   @default(pending)
  metadata         Json?
  completedAt      DateTime?       @map("completed_at") @db.Timestamptz
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  orders           Order[]
  refunds          Refund[]

  @@map("payments")
}

model Order {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  user           User            @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)
  courseId       String?         @map("course_id") @db.Uuid
  course         Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  companyId      String?         @map("company_id") @db.Uuid
  paymentId      String?         @map("payment_id") @db.Uuid
  payment        Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  totalAmount    Decimal         @map("total_amount") @db.Decimal(12, 2)
  currency       String          @default("INR") @db.Char(3)
  status         OrderStatus     @default(pending)
  classStartDate DateTime?       @map("class_start_date") @db.Date
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  refunds        Refund[]

  @@map("orders")
}

model Refund {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId            String       @map("order_id") @db.Uuid
  order              Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentId          String       @map("payment_id") @db.Uuid
  payment            Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount             Decimal      @db.Decimal(12, 2)
  reason             String       @db.Text
  status             RefundStatus @default(requested)
  requestedById      String       @map("requested_by") @db.Uuid
  requestedBy        User         @relation("RefundRequests", fields: [requestedById], references: [id], onDelete: Cascade)
  approvedById       String?      @map("approved_by") @db.Uuid
  approvedBy         User?        @relation("RefundApprovals", fields: [approvedById], references: [id], onDelete: SetNull)
  withinRefundWindow Boolean      @map("within_refund_window")
  gatewayRefundId    String?      @map("gateway_refund_id") @db.VarChar(255)
  processedAt        DateTime?    @map("processed_at") @db.Timestamptz
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("refunds")
}

model PaymentWebhookEvent {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gateway     PaymentGateway
  eventId     String         @map("event_id") @db.VarChar(255)
  eventType   String         @map("event_type") @db.VarChar(100)
  payload     Json
  processed   Boolean        @default(false)
  processedAt DateTime?      @map("processed_at") @db.Timestamptz
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz

  @@unique([gateway, eventId])
  @@map("payment_webhook_events")
}
