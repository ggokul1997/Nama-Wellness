  enrollmentId         String                   @map("enrollment_id") @db.Uuid
  enrollment           Enrollment               @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  recordingId          String                   @map("recording_id") @db.Uuid
  recording            Recording                @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  viewCount            Int                      @default(0) @map("view_count")
  lastViewedAt         DateTime?                @map("last_viewed_at") @db.Timestamptz
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([enrollmentId, recordingId])
  @@map("recording_views")
}

model RecordingAccessOverride {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId         String                   @map("enrollment_id") @db.Uuid
  enrollment           Enrollment               @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  recordingId          String                   @map("recording_id") @db.Uuid
  recording            Recording                @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  maxReplayCount       Int?                     @map("max_replay_count")
  grantedById          String                   @map("granted_by") @db.Uuid
  grantedBy            User                     @relation("RecordingOverrideGranter", fields: [grantedById], references: [id], onDelete: Restrict)
  reason               String?                  @map("reason") @db.Text
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz

  @@unique([enrollmentId, recordingId])
  @@map("recording_access_overrides")
